pos = new PVector(width/2, height/2);
vel = new PVector(2,-1);
}

void draw(){
 println (pos.x, pos.y);
 pos.add(vel);
rect(pos.x, pos.y,100,100);

if(pos.x + 100 > width){
vel.x *= -1;  
}

if(pos.x < 0){
  vel.x *= -1;
}

if(pos.y + 100 > height){
vel.y *= -1;  
}

if(pos.y < 0){
  vel.y *= -1;
}
fill(255,0,0);

}
