class Paleta {
  PVector pos;
  int ancho = 10;
  int alto = 100;

  Paleta(float p_x) {
    pos = new PVector(p_x, height/2);
  }
  void mostrar() {
    rectMode(CENTER);
    rect(pos.x, pos.y, ancho, alto);
  }

  void moverUP() {
    pos.y = pos.y - 5;
  }
  
  void moverDown() {
  }
}
