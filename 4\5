int maxPuntos = 10;
float[] posX = new float[maxPuntos];
float[] posY = new float[maxPuntos];

int indice = 0;
int cantidad = 0;

void setup() {
  size(800, 600);
}

void draw() {
  background(240);

  for (int i = 0; i < cantidad; i++) {
    ellipse(posX[i], posY[i], 20, 20);
  }
}

void mousePressed() {
  posX[indice] = mouseX;
  posY[indice] = mouseY;

  indice = (indice + 1) % maxPuntos;

  if (cantidad < maxPuntos) {
    cantidad++;
  }
}